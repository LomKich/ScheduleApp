<?xml version="1.0" encoding="utf-8"?>
<!--
    Кастомный layout для пункта настроек.
    Стиль: тёмный фон, основной текст белый, описание серое — как в Echo Nightly.
    Использование: PreferenceScreen или RecyclerView adapter.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="?attr/selectableItemBackground"
    android:paddingHorizontal="@dimen/spacing_xl"
    android:paddingVertical="@dimen/spacing_md"
    android:minHeight="@dimen/list_item_height"
    android:gravity="center_vertical">

    <!-- Иконка (опционально) -->
    <ImageView
        android:id="@+id/prefIcon"
        android:layout_width="@dimen/icon_lg"
        android:layout_height="@dimen/icon_lg"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:tint="@color/text_secondary"
        android:visibility="gone"
        android:scaleType="fitCenter" />

    <!-- Текстовый блок -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/prefTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_lg"
            android:textColor="@color/text_primary"
            android:textStyle="normal"
            android:lineSpacingMultiplier="1.1" />

        <TextView
            android:id="@+id/prefSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:textSize="@dimen/text_md"
            android:textColor="@color/text_secondary"
            android:lineSpacingMultiplier="1.2"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Trailing: Switch / стрелка / значение -->
    <FrameLayout
        android:id="@+id/prefTrailingContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md">

        <!-- Switch -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/prefSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:visibility="gone" />

        <!-- Значение (текст) -->
        <TextView
            android:id="@+id/prefValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:textSize="@dimen/text_md"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

        <!-- Стрелка вперёд -->
        <ImageView
            android:id="@+id/prefArrow"
            android:layout_width="@dimen/icon_md"
            android:layout_height="@dimen/icon_md"
            android:layout_gravity="center_vertical"
            android:src="@drawable/ic_chevron_right"
            android:tint="@color/text_hint"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
