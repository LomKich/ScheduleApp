<?xml version="1.0" encoding="utf-8"?>
<!--
    Тема приложения — только AppCompat, без com.google.android.material.
    Весь Material3 UI живёт в Compose (Theme.kt / Color.kt).
    XML-тема нужна только для: статус-бар, навбар, фон окна, нативные диалоги.
-->
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ══════════════════════════════════════════════════════
         Theme.Schedule  —  основная тема
         ══════════════════════════════════════════════════════ -->
    <style name="Theme.Schedule" parent="Theme.AppCompat.DayNight.NoActionBar">

        <!-- Статус-бар и навигационная панель -->
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/nav_bar</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>

        <!-- Фон окна — тёмный, без белой вспышки при запуске -->
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>

        <!-- Акцент для нативных View (ProgressBar, Switch, CheckBox) -->
        <item name="colorAccent">@color/accent_primary</item>
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorPrimaryDark">@color/bg_surface</item>

        <!-- Текст -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <!-- Нативный диалог -->
        <item name="android:alertDialogTheme">@style/Theme.Schedule.Dialog</item>
        <item name="alertDialogTheme">@style/Theme.Schedule.Dialog</item>

    </style>

    <!-- ══════════════════════════════════════════════════════
         Theme.CircleRecord  —  прозрачное окно для Camera2
         ══════════════════════════════════════════════════════ -->
    <style name="Theme.CircleRecord" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>

    <!-- ══════════════════════════════════════════════════════
         Dialog  —  тёмный AppCompat-диалог
         ══════════════════════════════════════════════════════ -->
    <style name="Theme.Schedule.Dialog" parent="Theme.AppCompat.DayNight.Dialog.Alert">
        <item name="android:background">@color/bg_dialog</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="colorAccent">@color/accent_primary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.Schedule.DialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.Schedule.DialogButton</item>
    </style>

    <style name="Widget.Schedule.DialogButton" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">@color/accent_primary</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>
